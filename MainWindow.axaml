<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VaultDaily.ViewModels"
        xmlns:ae="using:AvaloniaEdit"
        x:Class="VaultDaily.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="VaultDaily - Mon Journal"
        Width="1100"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#FDFBF7"
        Foreground="#4A3E3D">

    <Window.Styles>

        <Style Selector="Button.ToolbarBtn">
            <Setter Property="Background" Value="#F6EFE7"/>
            <Setter Property="Foreground" Value="#4A3E3D"/>
            <Setter Property="BorderBrush" Value="#E8DFD8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <Style Selector="Button.ToolbarBtn:pointerover">
            <Setter Property="Background" Value="#EDE1D6"/>
        </Style>

        <Style Selector="Button.ToolbarBtn:pressed">
            <Setter Property="Background" Value="#DCCCBD"/>
        </Style>

        <Style Selector="Button.SidebarBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6E5D53"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style Selector="TextBox.TitleBox">
            <Setter Property="FontFamily" Value="Georgia"/>
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2A1F1D"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#EFE6DD"/>
        </Style>

        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#E2D3C6"/>
        </Style>

    </Window.Styles>

    <Grid ColumnDefinitions="280,*">

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#F4EDE4"
                BorderBrush="#E4D8CC"
                BorderThickness="0,0,1,0">

            <Grid RowDefinitions="Auto,Auto,*"
                  Margin="20,24,16,20">

                <StackPanel Grid.Row="0"
                            Spacing="4"
                            Margin="0,0,0,22">

                    <TextBlock Text="VaultDaily"
                               FontFamily="Georgia"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#4A3E3D"/>

                    <TextBlock Text="Mes souvenirs"
                               FontFamily="Georgia"
                               FontStyle="Italic"
                               FontSize="15"
                               Foreground="#8C7A6B"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="#E9DDD2"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,0,0,16">

                    <StackPanel Spacing="2">
                        <TextBlock Text="Aujourd'hui"
                                   FontSize="12"
                                   Foreground="#8C7A6B"/>

                        <TextBlock Text="{Binding SelectedDate, StringFormat='{}{0:dd MMMM yyyy}'}"
                                   FontFamily="Georgia"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#4A3E3D"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="2">
                    <ListBox ItemsSource="{Binding AvailableDates}"
                             SelectedItem="{Binding SelectedDate}">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="10">

                                        <TextBlock Text="📜"
                                                   FontSize="15"
                                                   Foreground="#8C7A6B"/>

                                        <TextBlock Text="{Binding StringFormat='{}{0:dd MMM yyyy}'}"
                                                   FontFamily="Georgia"
                                                   FontSize="14"
                                                   Foreground="#6E5D53"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Contenu principal -->
        <Grid Grid.Column="1"
              RowDefinitions="Auto,Auto,*,Auto"
              Margin="48,34,48,34">

            <!-- En-tête -->
            <StackPanel Grid.Row="0"
                        Spacing="8"
                        Margin="0,0,0,20">

                <TextBlock Text="Journal du jour"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#A08D7D"/>

                <TextBox Classes="TitleBox"
                         PlaceholderText="Écrire l'histoire du jour..."
                         Text="{Binding Title, Mode=TwoWay}"/>
            </StackPanel>

            <!-- Toolbar -->
            <Border Grid.Row="1"
                    Background="#FFFDF9"
                    BorderBrush="#E8DFD8"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10"
                    Margin="0,0,0,14">

                <StackPanel Orientation="Horizontal"
                            Spacing="8">

                    <Button Classes="ToolbarBtn"
                            Click="OnBoldClicked">
                        <TextBlock Text="B"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Classes="ToolbarBtn"
                            Click="OnItalicClicked">
                        <TextBlock Text="I"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Classes="ToolbarBtn"
                            Click="OnUnderlineClicked">
                        <TextBlock Text="U"
                                   TextDecorations="Underline"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Border Width="1"
                            Height="24"
                            Background="#E8DFD8"
                            Margin="4,0"/>

                    <Border Background="#F6EFE7"
                            BorderBrush="#E8DFD8"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8,0"
                            Height="38">

                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">

                            <TextBlock Text="Couleur"
                                       FontSize="12"
                                       Foreground="#8C7A6B"
                                       VerticalAlignment="Center"/>

                            <ColorPicker x:Name="SelecteurCouleur"
                                         ColorChanged="OnColorPickerChanged"
                                         IsAlphaEnabled="False"
                                         Width="46"
                                         Height="28"
                                         Background="Transparent"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- Zone d'écriture -->
            <Border Grid.Row="2"
                    Background="#FFFDF9"
                    BorderBrush="#E8DFD8"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="0">

                <Grid RowDefinitions="Auto,*">

                    <Border Grid.Row="0"
                            Background="#F7EFE7"
                            CornerRadius="16,16,0,0"
                            Padding="18,10"
                            BorderBrush="#E8DFD8"
                            BorderThickness="0,0,0,1">

                        <TextBlock Text="Écris librement ce que tu veux garder de cette journée."
                                   FontSize="13"
                                   FontStyle="Italic"
                                   Foreground="#9A8778"/>
                    </Border>

                    <Border Grid.Row="1"
                            Padding="28,24,28,24"
                            Background="#FFFDF9"
                            CornerRadius="0,0,16,16">

                        <ae:TextEditor x:Name="RichEditor"
                                       FontFamily="Georgia, Times New Roman"
                                       FontSize="17"
                                       Background="Transparent"
                                       Foreground="#3F3431"
                                       ShowLineNumbers="False"
                                       WordWrap="True"
                                       HorizontalScrollBarVisibility="Disabled"
                                       VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Bas de page -->
            <Grid Grid.Row="3"
                  ColumnDefinitions="*,Auto"
                  Margin="0,20,0,0">

                <TextBlock Grid.Column="0"
                           Text="Tes entrées sont sauvegardées localement."
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="#A08D7D"/>

                <Button Grid.Column="1"
                        Content="Sceller cette journée"
                        Click="OnSaveClicked"
                        HorizontalAlignment="Right"
                        Padding="22,11"
                        Background="#8C7A6B"
                        Foreground="White"
                        BorderThickness="0"
                        CornerRadius="22"
                        FontWeight="Medium"/>
            </Grid>
        </Grid>
    </Grid>
</Window>